{
  "name": "onepagecrm-mcp-server",
  "version": "0.1.0",
  "description": "A small MCP server that exposes safe OnePage CRM tools for ChatGPT and other MCP clients.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "tsx src/index.ts --http",
    "dev:stdio": "tsx src/index.ts --stdio",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --http",
    "start:stdio": "node dist/index.js --stdio",
    "test:connection": "tsx src/testConnection.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "dotenv": "16.4.7",
    "express": "4.21.2",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "22.10.5",
    "tsx": "4.19.2",
    "typescript": "5.7.2"
  }
}
